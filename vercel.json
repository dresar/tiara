{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.8.0"
        },
        "api/index.php": {
            "runtime": "vercel-php@0.8.0"
        },
        "index.php": {
            "runtime": "vercel-php@0.8.0"
        },
        "koneksi.php": {
            "runtime": "vercel-php@0.8.0"
        }
    },
    "routes": [
        { "src": "/assets/(.*)", "dest": "/assets/$1" },
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "src": "/(.*)", "dest": "/index.php" }
    ]
}
